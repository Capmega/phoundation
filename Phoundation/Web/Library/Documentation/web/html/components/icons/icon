PHP code to render an icon would be something like this:
public function render(): ?string
{
    switch ($this->getVendor()) {
        case 'lucide':
            return '<svg class="lucide icon"><use xlink:href="https://yourcdn.com/icons.svg#icon-' . $this->getLabel() . '"></use></svg>';
        default:
            return '<i class="' . $this->getVendor() . ' ' . $this->getLabel() . '"></i>';
    }
}

